NODE_ENV=development
DATABASE_URL=postgres://eventuser:eventpass@localhost:5432/eventdb
HMAC_SECRET=change_this_to_a_random_secret
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@event.local
